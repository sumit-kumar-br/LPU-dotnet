@model IEnumerable<StudentManagementSystem.Models.Department>
@{
    ViewData["Title"] = "Departments";
}

<div class="action-bar">
    <h2 class="page-title mb-0">Department List</h2>
    <a asp-action="Create" class="btn btn-primary">Add Department</a>
</div>

<div class="card p-3">
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Department Name</th>
                <th>Description</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DepartmentName</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-danger" data-confirm="Delete this department?">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
