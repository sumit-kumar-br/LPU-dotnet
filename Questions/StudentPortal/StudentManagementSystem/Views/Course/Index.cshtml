@model IEnumerable<StudentManagementSystem.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="action-bar">
    <h2 class="page-title mb-0">Course List</h2>
    <a asp-action="Create" class="btn btn-primary">Add Course</a>
</div>

<div class="card p-3">
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Course Name</th>
                <th>Duration</th>
                <th>Fees</th>
                <th>Department</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.Duration</td>
                    <td>@item.Fees.ToString("C")</td>
                    <td>@item.Department?.DepartmentName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger" data-confirm="Delete this course?">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
