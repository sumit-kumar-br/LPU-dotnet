@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Delete Student";
}

<h2 class="page-title mb-3">Delete Student</h2>

<div class="card p-4">
    <p>Are you sure you want to delete this student record?</p>
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.StudentName</dd>
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.Department?.DepartmentName</dd>
        <dt class="col-sm-3">Course</dt>
        <dd class="col-sm-9">@Model.Course?.CourseName</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input asp-for="StudentId" type="hidden" />
        <button type="submit" class="btn btn-danger" data-confirm="This action cannot be undone. Continue?">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
