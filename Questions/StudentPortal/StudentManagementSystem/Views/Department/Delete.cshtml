@model StudentManagementSystem.Models.Department
@{
    ViewData["Title"] = "Delete Department";
}

<h2 class="page-title mb-3">Delete Department</h2>

<div class="card p-4">
    <p>Are you sure you want to delete this department?</p>
    <dl class="row">
        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.DepartmentName</dd>
        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input asp-for="DepartmentId" type="hidden" />
        <button type="submit" class="btn btn-danger" data-confirm="This action cannot be undone. Continue?">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
