@model IEnumerable<EFDemo.Models.Student>

@* @model List<Student> *@

@{
  ViewData["Title"] = "Students";
  var q = (ViewBag.Query as string) ?? "";
}

<div class="card">
  <div class="row">
    <div>
      <h2 class="page-title">Students</h2>
    </div>
    <a class="btn btn-primary" asp-action="Create">+ Add Student</a>
  </div>

  <div class="row" style="margin-top:14px; align-items:flex-end;">
    <div style="flex:1; max-width:420px;">
      <label for="q" class="control-label small" style="margin-bottom:4px;">Search</label>
      <input id="q" class="input" placeholder="Type a name or email and pause to search..." value="@q" />
    </div>
    <button id="btnSearch" class="btn" type="button">Search</button>
  </div>

  <div id="liveBox" class="small muted" style="margin-top:8px"></div>

  <table class="tbl">
    <thead>
      <tr><th>Id</th><th>Name</th><th>Email</th><th>Phone</th><th>Join Date</th><th>Status</th><th style="width:200px">Actions</th></tr>
    </thead>
    <tbody id="tblBody">
    @foreach (var s in Model)
    {
      <tr>
        <td>@s.StudentId</td>
        <td>@s.FullName</td>
        <td>@s.Email</td>
        <td>@s.Phone</td>
        <td>@s.JoinDate</td>
        <td>
          <span class="status-pill @(s.Status == "Active" ? "status-pill--active" : "status-pill--inactive")">
            @s.Status
          </span>
        </td>
        <td>
          <a class="btn" asp-action="Edit" asp-route-id="@s.StudentId">Edit</a>
          <a class="btn" asp-action="Delete" asp-route-id="@s.StudentId">Delete</a>
        </td>
      </tr>
    }
    </tbody>
  </table>
</div>

@section Scripts{
<script>
  const qEl = document.getElementById("q");
  const box = document.getElementById("liveBox");
  const tbody = document.getElementById("tblBody");
  const btn = document.getElementById("btnSearch");

  let t = null;

  function renderRows(items){
    if(!items || items.length === 0){
      tbody.innerHTML = `<tr><td colspan="7">No results</td></tr>`;
      return;
    }
    tbody.innerHTML = items.map(s => `
      <tr>
        <td>${s.studentId}</td>
        <td>${s.fullName}</td>
        <td>${s.email}</td>
        <td>${s.phone ?? ""}</td>
        <td>${s.joinDate ?? ""}</td>
        <td>
          <span class="status-pill ${s.status === "Active" ? "status-pill--active" : "status-pill--inactive"}">
            ${s.status ?? ""}
          </span>
        </td>
        <td>
          <a class="btn" href="/Students/Edit/${s.studentId}">Edit</a>
          <a class="btn" href="/Students/Delete/${s.studentId}">Delete</a>
        </td>
      </tr>
    `).join("");
  }

  async function liveSearch(){
    const q = qEl.value.trim();
    if(q.length === 0){
      box.textContent = "";
      return;
    }
    box.textContent = "Searching...";
    const res = await fetch(`/Students/Search?q=${encodeURIComponent(q)}`);
    const data = await res.json();
    box.textContent = `Found: ${data.length}`;
    renderRows(data);
  }

  qEl.addEventListener("keyup", () => {
    clearTimeout(t);
    t = setTimeout(liveSearch, 250);
  });
  btn.addEventListener("click", liveSearch);
</script>
}
